<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".ShopAssistApp"
        android:allowBackup="true"
        android:icon="@drawable/logo_shopassist"
        android:label="@string/app_name"
        android:roundIcon="@drawable/logo_shopassist"
        android:supportsRtl="true"
        android:theme="@style/Theme.ShopAssist">

        <activity android:name=".activities.AdminDashboardActivity" />
        <activity android:name=".activities.AccessibilitySettingsActivity" />
        <activity android:name=".activities.ReviewActivity" />
        <activity android:name=".activities.ChatActivity" />
        <activity android:name=".activities.ShopperProfileActivity" />
        <activity android:name=".activities.ShopperActiveRequestActivity" />
        <activity android:name=".activities.RequestDetailsActivity" />
        <activity android:name=".activities.ShopperHomeActivity" />
        <activity android:name=".activities.CustomerRequestActivity" />
        <activity android:name=".activities.DeliveryDetailsActivity" />
        <activity android:name=".activities.CreateRequestActivity" />
        <activity android:name=".activities.CustomerHomeActivity" />
        <activity android:name=".activities.DashboardPlaceholderActivity" />
        <activity android:name=".activities.RoleSelectionActivity" />
        <activity android:name=".activities.RegisterActivity" />
        <activity
            android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
